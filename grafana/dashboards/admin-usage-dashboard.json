      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "(increase(glop_admin_signin_duration_seconds_sum[1d]) / clamp_min(increase(glop_admin_signin_duration_seconds_count[1d]), 1)) or vector(0)",
          "legendFormat": "Duree moyenne signin",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Temps moyen de connexion",
      "type": "stat"
